#include <stdio.h>
#include <stdlib.h>
#include <time.h>
main(){
	int i,a[5],b[5],c[5];
	srand(time(NULL));
	for (i=0;i<5;i++){
		a[i]=rand()%100;
		printf("A[%d] = %d\n",i,a[i]);
	}
	printf("\nvet b:\n");
	for (i=0;i<5;i++){
		b[i]=rand()%100;
		printf("%d ",b[i]);
	}
	printf("\n");
	for(i=0;i<5;i++){
		c[i] = a[i]+b[i];
	printf("C[%d] = %d\n",i,c[i]);
	}
	

	
}
